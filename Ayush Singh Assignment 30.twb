          <filter class='categorical' column='[federated.1i3q6020lpbe3q1cmvdow0kc3ar1].[usr:Calculation_1075927117791234:nk:1]'>
            <groupfilter function='member' level='[usr:Calculation_1075927117791234:nk:1]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
